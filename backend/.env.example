# Backend Environment Variables
# Copy this to .env and fill in your actual values

# MongoDB Connection URI
# For local MongoDB: mongodb://localhost:27017/learntales
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/learntales
MONGO_URI=mongodb://localhost:27017/learntales

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Frontend URL (for email links, CORS, certificate URLs)
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d

# Razorpay Payment Gateway Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_from_dashboard
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_from_dashboard

# Email Configuration (Nodemailer)
# For Gmail: Use an App-specific password (not your regular password)
# Visit: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# Logging
LOG_LEVEL=info
